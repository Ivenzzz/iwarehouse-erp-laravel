{
  "name": "RMATransfers",
  "type": "object",
  "properties": {
    "transfer_number": {
      "type": "string",
      "description": "Unique transfer number (e.g., RMAT-2025-00001)"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending_pickup",
        "in_transit",
        "received",
        "completed",
        "cancelled"
      ],
      "default": "pending_pickup"
    },
    "source_warehouse_id": {
      "type": "string",
      "description": "Branch/warehouse where items are being picked up"
    },
    "destination_warehouse_id": {
      "type": "string",
      "description": "Main warehouse or service center receiving the items"
    },
    "items": {
      "type": "array",
      "description": "Array of RMA items included in this transfer",
      "items": {
        "type": "object",
        "properties": {
          "rma_ticket_id": {
            "type": "string"
          },
          "ticket_number": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "brand_name": {
            "type": "string"
          },
          "variant_name": {
            "type": "string"
          },
          "imei1": {
            "type": "string"
          },
          "imei2": {
            "type": "string"
          },
          "serial_number": {
            "type": "string"
          },
          "customer_name": {
            "type": "string"
          },
          "return_reason": {
            "type": "string"
          }
        }
      }
    },
    "transfer_data": {
      "type": "object",
      "description": "Additional transfer metadata",
      "properties": {
        "total_items": {
          "type": "number"
        },
        "source_warehouse_name": {
          "type": "string"
        },
        "destination_warehouse_name": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "dates": {
      "type": "object",
      "properties": {
        "scheduled_pickup_date": {
          "type": "string",
          "format": "date-time"
        },
        "actual_pickup_date": {
          "type": "string",
          "format": "date-time"
        },
        "received_date": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "actors": {
      "type": "object",
      "properties": {
        "created_by": {
          "type": "string"
        },
        "created_by_name": {
          "type": "string"
        },
        "picked_up_by": {
          "type": "string"
        },
        "received_by": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "transfer_number",
    "status",
    "source_warehouse_id",
    "items"
  ]
}