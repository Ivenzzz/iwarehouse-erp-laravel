{
  "name": "Supplier",
  "type": "object",
  "properties": {
    "supplier_code": {
      "type": "string",
      "description": "Unique supplier identifier"
    },
    "master_profile": {
      "type": "object",
      "description": "Core identification and master data",
      "properties": {
        "legal_business_name": {
          "type": "string",
          "description": "Official registered name"
        },
        "trade_name": {
          "type": "string",
          "description": "Brand/trading name"
        },
        "supplier_type": {
          "type": "string",
          "enum": [
            "Manufacturer",
            "Distributor",
            "Wholesaler",
            "Importer",
            "Service Provider"
          ],
          "description": "Type of supplier"
        },
        "business_classification": {
          "type": "string",
          "enum": [
            "Corporation",
            "Partnership",
            "Sole Proprietor"
          ],
          "description": "Legal entity type"
        },
        "status": {
          "type": "string",
          "enum": [
            "Active",
            "On-Hold",
            "Blacklisted",
            "Archived"
          ],
          "default": "Active",
          "description": "Current supplier status"
        },
        "primary_currency": {
          "type": "string",
          "description": "Default transaction currency"
        },
        "country_of_registration": {
          "type": "string",
          "description": "Country where business is registered"
        }
      }
    },
    "legal_tax_compliance": {
      "type": "object",
      "description": "Legal and tax information",
      "properties": {
        "tin_vat_number": {
          "type": "string",
          "description": "Tax Identification Number / VAT Registration"
        },
        "vat_type": {
          "type": "string",
          "enum": [
            "VAT Registered",
            "Non-VAT",
            "Zero-Rated"
          ],
          "description": "VAT status"
        },
        "business_registration_number": {
          "type": "string",
          "description": "SEC / DTI / CDA number"
        },
        "registered_address": {
          "type": "string",
          "description": "Official BIR registered address"
        }
      }
    },
    "contact_details": {
      "type": "object",
      "description": "Primary contact information",
      "properties": {
        "main_contact_person": {
          "type": "string"
        },
        "position_department": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "mobile_landline": {
          "type": "string"
        },
        "preferred_channel": {
          "type": "string",
          "enum": [
            "Email",
            "WhatsApp",
            "Viber",
            "SMS",
            "Facebook Messenger"
          ],
          "description": "Preferred communication method"
        }
      }
    },
    "rma_contact": {
      "type": "object",
      "description": "RMA point of contact and policies",
      "properties": {
        "name": {
          "type": "string"
        },
        "job_title": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone_number": {
          "type": "string"
        },
        "shipping_address": {
          "type": "object",
          "properties": {
            "street": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "state_province": {
              "type": "string"
            },
            "zip_code": {
              "type": "string"
            },
            "country": {
              "type": "string"
            }
          }
        },
        "courier_account_number": {
          "type": "string"
        },
        "warranty_duration": {
          "type": "string",
          "description": "e.g., 12 months, 24 months"
        },
        "sop": {
          "type": "object",
          "properties": {
            "rma_validity_period": {
              "type": "string",
              "description": "e.g., 30 days from purchase"
            },
            "minimum_return_value": {
              "type": "number"
            },
            "restocking_fee": {
              "type": "string",
              "description": "e.g., 15%, $50"
            },
            "shipping_payment_terms": {
              "type": "string",
              "description": "e.g., Prepaid by customer, Supplier pays return shipping"
            },
            "initiation_method": {
              "type": "string",
              "enum": [
                "Online Portal",
                "Email Request",
                "Phone Call",
                "Auto-Approve"
              ]
            },
            "required_evidence": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "Photo of Damage",
                  "Serial Number Scan",
                  "Proof of Purchase/Invoice",
                  "Error Log/Debug Report"
                ]
              }
            },
            "approval_turnaround_time": {
              "type": "string",
              "description": "e.g., 48 Hours"
            },
            "packaging_requirement": {
              "type": "string",
              "description": "e.g., Original Box Only, Double Boxed, Anti-Static Bag Required"
            },
            "labeling_instruction": {
              "type": "string",
              "description": "e.g., Write RMA# on outside of box in black marker"
            },
            "invoice_copies_required": {
              "type": "number",
              "description": "Number of invoice copies required"
            }
          }
        },
        "sop_document_url": {
          "type": "string",
          "description": "URL to uploaded full SOP document"
        },
        "rma_request_template_url": {
          "type": "string",
          "description": "URL to uploaded RMA request template"
        }
      }
    },
    "financial_payment_terms": {
      "type": "object",
      "description": "Financial and payment configurations",
      "properties": {
        "payment_terms": {
          "type": "string",
          "enum": [
            "COD",
            "7 Days",
            "15 Days",
            "30 Days",
            "45 Days",
            "60 Days",
            "Consignment"
          ],
          "description": "Default payment terms"
        },
        "credit_limit": {
          "type": "number",
          "description": "Maximum credit allowed"
        },
        "early_payment_discount": {
          "type": "string",
          "description": "e.g., 2% / 10 days"
        },
        "penalty_late_fee_rules": {
          "type": "string",
          "description": "Late payment penalties"
        },
        "default_price_basis": {
          "type": "string",
          "enum": [
            "Cost-based",
            "SRP-linked",
            "Contract pricing"
          ],
          "description": "Pricing methodology"
        }
      }
    },
    "bank_disbursement": {
      "type": "object",
      "description": "Banking and disbursement details",
      "properties": {
        "bank_name": {
          "type": "string"
        },
        "account_name": {
          "type": "string"
        },
        "account_number": {
          "type": "string"
        },
        "account_type": {
          "type": "string",
          "description": "e.g., Savings, Current"
        },
        "swift_bank_code": {
          "type": "string"
        },
        "preferred_payment_method": {
          "type": "string",
          "enum": [
            "Bank Transfer",
            "Check",
            "Digital Wallet"
          ],
          "description": "Preferred disbursement method"
        }
      }
    },
    "logistics_delivery": {
      "type": "object",
      "description": "Logistics and delivery information",
      "properties": {
        "default_delivery_address": {
          "type": "string"
        },
        "shipping_origin": {
          "type": "string"
        },
        "lead_time_days": {
          "type": "number",
          "description": "Standard lead time in days"
        },
        "delivery_schedule": {
          "type": "string",
          "description": "e.g., Mon-Fri, 9AM-5PM"
        },
        "freight_terms": {
          "type": "string",
          "enum": [
            "Delivered",
            "FOB",
            "Ex-Warehouse"
          ],
          "description": "Freight arrangement"
        },
        "courier_forwarder": {
          "type": "string",
          "description": "Default courier or forwarder"
        },
        "incoterms": {
          "type": "string",
          "description": "For imports (e.g., CIF, FOB, DDP)"
        }
      }
    },
    "product_commercial": {
      "type": "object",
      "description": "Product and commercial relationship",
      "properties": {
        "authorized_brands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of brands this supplier is authorized for"
        },
        "product_categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Product categories supplied"
        },
        "warranty_policy": {
          "type": "string",
          "description": "Warranty terms and conditions"
        }
      }
    },
    "performance_risk": {
      "type": "object",
      "description": "Performance metrics and risk assessment",
      "properties": {
        "supplier_rating": {
          "type": "object",
          "properties": {
            "price_competitiveness": {
              "type": "number",
              "description": "1-5 scale"
            },
            "delivery_reliability": {
              "type": "number",
              "description": "1-5 scale"
            },
            "defect_rate": {
              "type": "number",
              "description": "1-5 scale (lower is better)"
            },
            "rma_tat": {
              "type": "number",
              "description": "1-5 scale"
            }
          }
        },
        "on_time_delivery_percentage": {
          "type": "number",
          "description": "OTD % metric"
        },
        "quality_issues_logged": {
          "type": "integer",
          "description": "Number of quality incidents"
        },
        "last_audit_date": {
          "type": "string",
          "format": "date",
          "description": "Last supplier audit"
        },
        "blacklist_reason": {
          "type": "string",
          "description": "Reason if blacklisted"
        }
      }
    },
    "compliance_certifications": {
      "type": "object",
      "description": "Certifications and compliance",
      "properties": {
        "iso_9001": {
          "type": "boolean",
          "default": false
        },
        "iso_27001": {
          "type": "boolean",
          "default": false
        },
        "other_certifications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "diversity_esg": {
      "type": "object",
      "description": "Diversity and ESG data",
      "properties": {
        "diversity_classification": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Minority-owned",
              "Women-owned",
              "Veteran-owned",
              "Small Business"
            ]
          }
        },
        "sustainability_notes": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "supplier_code",
    "master_profile",
    "contact_details"
  ]
}